# Supabase — when you connect Supabase through the Vercel integration, Vercel
# injects these automatically in the cloud. For local dev, copy this file to
# .env.local and fill in the values from your Supabase project settings (API).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Note: the Vercel Supabase integration may name the URL var SUPABASE_URL.
# lib/supabase.ts reads NEXT_PUBLIC_SUPABASE_URL first, then falls back.
